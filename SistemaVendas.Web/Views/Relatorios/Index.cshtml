@model IEnumerable<SistemaVendas.Domain.Entities.RelatorioSolicitacao>


<h1>Relatórios</h1>


<p>

	<a asp-action="Solicitar"
	   class="btn btn-primary">

		Novo Relatório

	</a>

</p>



<table class="table">


	<thead>

		<tr>

			<th>
				Tipo
			</th>

			<th>
				Solicitado em
			</th>

			<th>
				Status
			</th>


			<th>
				Conclusão
			</th>


		</tr>

	</thead>


	<tbody>


		@foreach (var item in Model)
		{


			<tr>

				<td>
					@item.TipoRelatorio
				</td>
				<td>
					@item.DataSolicitacao
				</td>


				<td>
					@item.Status
				</td>


				<td>
					@item.DataConclusao
				</td>
				<td>
					@if (item.Status == "Pendente")
					{
						<form asp-action="Cancelar"
							  method="post"
							  class="d-inline">

							<input type="hidden"
								   name="id"
								   value="@item.Id" />

							<button class="btn btn-danger btn-sm">

								Cancelar

							</button>

						</form>
					}
				</td>
				<td>
				@if (!string.IsNullOrWhiteSpace(item.ArquivoGerado))
				{
					<a class="btn btn-success btn-sm mt-2"
					   asp-controller="Relatorios"
					   asp-action="Download"
					   asp-route-id="@item.Id">

						📄 Baixar relatório

					</a>
				}
				</td>
			</tr>


		}


	</tbody>


</table>